modules = ["nodejs-20", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start workflow"
mode = "sequential"
author = 51298281

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dev-server"

[[workflows.workflow]]
name = "dev-server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd heartfelt-check-in-main && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 3001
externalPort = 8000

[[ports]]
localPort = 3002
externalPort = 8008

[[ports]]
localPort = 3003
externalPort = 8080

[[ports]]
localPort = 3004
externalPort = 8081

[[ports]]
localPort = 3005
externalPort = 8099

[[ports]]
localPort = 3006
externalPort = 9000

[[ports]]
localPort = 4000
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 4200

[[ports]]
localPort = 5005
externalPort = 5000

[[ports]]
localPort = 5006
externalPort = 5173

[[ports]]
localPort = 5007
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "npm run start"]
build = ["sh", "-c", "npm run build"]
